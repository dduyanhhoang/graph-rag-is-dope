# ============================================
# Environment Variables for GraphRAG Lab
# ============================================

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1  # Optional: change for proxies/alternatives

# LLM Models (adjust based on your budget/needs)
# For entity extraction and answer generation
OPENAI_MODEL=gpt-4o-mini          # Cost-effective, good for lab
# OPENAI_MODEL=gpt-4o            # Higher quality, more expensive
# OPENAI_MODEL=gpt-4-turbo       # Fast, good quality

# Embedding Model Configuration
# Choose ONE of the following embedding strategies:

# Option 1: OpenAI Embeddings (high quality, paid)
EMBEDDING_MODEL=text-embedding-3-small  # or text-embedding-ada-002
USE_OPENAI_EMBEDDINGS=true

# Option 2: Sentence Transformers (free, local) - RECOMMENDED for lab
# EMBEDDING_MODEL=all-MiniLM-L6-v2     # Fast, small (384 dims)
# EMBEDDING_MODEL=all-mpnet-base-v2    # Better quality (768 dims)
USE_OPENAI_EMBEDDINGS=false

# Optional: HuggingFace token (if using gated models)
# HF_TOKEN=your-huggingface-token

# Neo4j Configuration (only if using Neo4j instead of NetworkX)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-password

# Debug/Development
DEBUG=false
LOG_LEVEL=INFO
